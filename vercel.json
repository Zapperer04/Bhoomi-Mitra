{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "public": true,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    },
    {
      "src": "*.jpg",
      "use": "@vercel/static"
    },
    {
      "src": "*.svg",
      "use": "@vercel/static"
    },
    {
      "src": "*.ico",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/farmer/dashboard", "destination": "/farmer_dashboard.html" },
    { "source": "/contractor/dashboard", "destination": "/contractor_dashboard.html" },
    { "source": "/chatbot", "destination": "/Chatbot.html" },
    { "source": "/gov", "destination": "/gov.html" },
    { "source": "/messages", "destination": "/messages.html" },
    { "source": "/profile", "destination": "/Profile.html" },
    { "source": "/post-crop", "destination": "/post_crop.html" },
    { "source": "/signup", "destination": "/Signup.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/farmer/help", "destination": "/farmer_help.html" },
    { "source": "/contractor/help", "destination": "/contractor_help.html" }
  ]
}
